{
  "expo": {
    "name": "QRIFY",
    "slug": "Qrify-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ravenidmobile",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon_splash.png",
        "backgroundImage": "./assets/images/icon_splash.png",
        "monochromeImage": "./assets/images/icon_splash.png"
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.remsix.Qrifyapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7222232d-1cd0-4e0f-a8e0-edcb8c8755ea"
      }
    },
    "owner": "remsix"
  }
}
